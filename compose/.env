ROS_DOMAIN_ID=42
ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

DISPLAY=:0
WAYLAND_DISPLAY=wayland-0
XDG_RUNTIME_DIR=/mnt/wslg/runtime-dir

SICK_LAUNCH_FILE=sick_tim_5xx.launch.py
SICK_FRONT_IP=192.168.0.52
SICK_REAR_IP=192.168.0.51
SICK_FRONT_FRAME=sick_front_link
SICK_REAR_FRAME=sick_rear_link

RS_FRONT_SERIAL=
# 947522071563
RS_REAR_SERIAL= 
# 948122071619

CYCLONEDDS_CONFIG=unicast_docker
CYCLONEDDS_URI=file:///etc/cyclonedds/cyclonedds.xml

ROBOT_LOCALIZATION_SHA=3efa714fb9c1ff40966327b7bed7053b2570be4d
LOCALIZATION_CONFIG=/ws/config/localization/local_ekf.yaml
ROBOSENSE_REF=parameter_test_feld

# u-blox ZED-F9P
GPS_PORT=auto
GPS_DEVICE_PATTERN=u-blox|ublox|ardusimple|zed|f9p|gnss|gps
GPS_CONFIG_FILE=/etc/floribot/gps/zed_f9p_rover.yaml

GPS_NODE_NAME=ublox_gps_node
GPS_FRAME_ID=gps_link
GPS_RATE=10.0
GPS_NAV_RATE=1
GPS_DYNAMIC_MODEL=automotive

GPS_FIX_TOPIC=/sensors/gps/fix
GPS_VEL_TOPIC=/sensors/gps/fix_velocity

GPS_SCAN_INTERVAL_SEC=2
GPS_RESTART_DELAY_SEC=2

# Erst aktivieren, wenn IMU und /odometry/filtered verfügbar sind.
NAVSAT_ENABLE=false

NAVSAT_FREQUENCY=30.0
NAVSAT_DELAY=1.0
NAVSAT_MAGNETIC_DECLINATION_RAD=0.0
NAVSAT_YAW_OFFSET_RAD=0.0
NAVSAT_ZERO_ALTITUDE=true
NAVSAT_PUBLISH_FILTERED_GPS=true
NAVSAT_USE_ODOMETRY_YAW=false
NAVSAT_WAIT_FOR_DATUM=false
NAVSAT_BROADCAST_UTM_TRANSFORM=false
NAVSAT_BROADCAST_UTM_TRANSFORM_AS_PARENT_FRAME=false
NAVSAT_TRANSFORM_TIMEOUT=0.2

NAVSAT_IMU_TOPIC=/imu/data
NAVSAT_ODOM_FILTERED_TOPIC=/odometry/filtered

PTU_PORT=/dev/ttyUSB0
NAVSAT_ODOM_GPS_TOPIC=/odometry/gps
NAVSAT_FILTERED_GPS_TOPIC=/gps/filtered

DETECTOR_USE_REALSENSE_ROS_WRAPPER=false
